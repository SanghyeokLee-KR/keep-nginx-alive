        <mxCell id="t" parent="1" style="text;html=1;align=left;fontSize=22;fontStyle=1;fontColor=#232F3E;" value="헬스체크 자가격리 (Fail-Open) — 오염되면 스스로 채점망에서 빠진다" vertex="1">
