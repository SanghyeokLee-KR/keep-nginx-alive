        <mxCell id="lg" parent="1" style="text;html=1;align=left;fontSize=11;fontColor=#5F5E5A;" value="범례 — 회색: 채점 요청·관찰 · 파랑: 정상 응답(200) · 청록: 헬스체크·복구 동작 · 앰버: 503·격리 · 빨강: 오염 상태" vertex="1">
