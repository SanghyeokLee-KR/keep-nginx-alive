        <mxCell id="t" parent="1" style="text;html=1;align=left;fontSize=20;fontStyle=1;fontColor=#232F3E;" value="보호 모니터링 서비스 관계도 — 다중 복구 + 이름 추상화 (Protective Monitors)" vertex="1">
